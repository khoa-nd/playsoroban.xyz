// PlaySoroban.xyz - Math Challenge App Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
}

// User model - supports both parent and child accounts
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Simple password storage (not for production)
  name      String
  role      String   @default("child") // "parent" or "child"
  language  String   @default("en") // "en" or "vi"
  geminiApiKey String? // User's own Gemini API key
  questionMode String  @default("local") // "local" or "ai"
  parentId  String?  // If child, reference to parent
  parent    User?    @relation("ParentChild", fields: [parentId], references: [id])
  children  User[]   @relation("ParentChild")

  // Gamification stats
  totalXp       Int @default(0)
  currentLevel  Int @default(1)
  currentStreak Int @default(0)
  longestStreak Int @default(0)
  lastActiveAt  DateTime?

  // Relations
  challengeAttempts ChallengeAttempt[]
  earnedBadges      UserBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Daily challenges generated by AI
model Challenge {
  id          String   @id @default(cuid())
  date        DateTime @default(now()) // The day this challenge is for

  // Challenge content
  type        String   // "addition", "subtraction", "counting", "pattern", "comparison"
  difficulty  Int      @default(1) // 1-5 scale
  question    String   // The question text
  questionData String? // JSON for visual/interactive elements
  answer      String   // Correct answer
  options     String?  // JSON array of multiple choice options (if applicable)
  hint        String?  // Optional hint
  explanation String?  // Explanation of the answer

  // Metadata
  xpReward    Int @default(10)

  attempts    ChallengeAttempt[]

  createdAt   DateTime @default(now())
}

// Track user attempts at challenges
model ChallengeAttempt {
  id          String   @id @default(cuid())
  userId      String
  challengeId String

  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  userAnswer  String
  isCorrect   Boolean
  timeTaken   Int?      // Seconds to complete
  xpEarned    Int       @default(0)
  attemptNumber Int     @default(1) // Which attempt this was

  createdAt   DateTime @default(now())

  @@index([userId, challengeId])
}

// Badge definitions
model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String // Emoji or icon name
  category    String // "streak", "accuracy", "speed", "milestone"
  requirement String // JSON describing unlock criteria
  xpBonus     Int    @default(0)

  earnedBy    UserBadge[]
}

// Track which users have earned which badges
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String

  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
}

// Local questions from Cambridge workbook
model LocalQuestion {
  id          String   @id @default(cuid())
  unit        Int      // Unit number (1-7)
  exercise    String   // Exercise number (e.g., "1.1", "1.2")
  questionNum Int      // Question number within exercise

  // Content - stored in both languages
  questionEn  String   // English question text
  questionVi  String   // Vietnamese question text
  answerEn    String   // English answer
  answerVi    String   // Vietnamese answer

  // Question metadata
  type        String   // "fill_blank", "calculation", "word_problem", "comparison", "pattern", "challenge"
  difficulty  Int      @default(1) // 1-3
  hasImage    Boolean  @default(false)

  // For multiple choice (generated options)
  options     String?  // JSON array of options (generated at runtime if needed)

  hintEn      String?  // English hint
  hintVi      String?  // Vietnamese hint
  explanationEn String? // English explanation
  explanationVi String? // Vietnamese explanation

  xpReward    Int      @default(10)

  createdAt   DateTime @default(now())
}
